# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Environment / secrets
.env

# Local data (raw scrapes and the dev database are rebuildable, never
# committed). Model artifacts ARE committed: they are <1 MB per version and
# the weekly GitHub Actions prediction job loads them straight from the repo.
data/raw/*
!data/raw/.gitkeep
data/*.db

# Node (frontend, later phases)
node_modules/
.next/

# OS / editor
Thumbs.db
.DS_Store
.vscode/
.idea/

# Personal notes (never committed)
notes/
