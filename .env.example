# Copy to .env and adjust. Defaults to a local SQLite file if unset.
# Local Postgres: postgresql+psycopg://genpicks:genpicks-local@127.0.0.1:5433/genpicks
# Hosted Postgres (Neon/Supabase): postgresql+psycopg://<user>:<password>@<host>/<db>
GENPICKS_DATABASE_URL=sqlite:///data/genpicks.db

# Live market odds: free key from https://the-odds-api.com (Starter tier)
GENPICKS_ODDS_API_KEY=
